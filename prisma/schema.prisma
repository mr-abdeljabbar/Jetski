generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("ASSISTANT")
  createdAt DateTime @default(now())
}

model Activity {
  id                 String             @id @default(uuid())
  title              String
  description        String
  category           String
  maxPersons         Int
  location           String
  safetyInfo         String
  equipmentIncluded  String
  rating             Float              @default(5.0)
  createdAt          DateTime           @default(now())
  backgroundImageUrl String?
  isActive           Boolean            @default(true)
  slug               String?            @unique
  updatedAt          DateTime           @updatedAt
  durations          ActivityDuration[]
  images             ActivityImage[]
  bookings           Booking[]

  @@index([category])
  @@index([isActive])
}

model ActivityImage {
  id         String   @id @default(uuid())
  activityId String
  imageUrl   String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model ActivityDuration {
  id            String    @id @default(uuid())
  activityId    String
  durationLabel String
  price         Float
  activity      Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  bookings      Booking[]
}

model Booking {
  id         String            @id @default(uuid())
  activityId String
  durationId String?
  fullName   String
  phone      String
  persons    Int
  isMultiDay Boolean           @default(false)
  time       String?
  status     String            @default("pending")
  createdAt  DateTime          @default(now())
  notes      String?
  updatedAt  DateTime          @updatedAt
  startDate  DateTime
  endDate    DateTime?
  activity   Activity          @relation(fields: [activityId], references: [id], onDelete: Cascade)
  duration   ActivityDuration? @relation(fields: [durationId], references: [id])

  @@index([activityId])
  @@index([status])
  @@index([startDate])
}

model ContactMessage {
  id        String   @id @default(uuid())
  fullName  String
  phone     String
  subject   String
  activity  String?
  message   String
  status    String   @default("unread")
  createdAt DateTime @default(now())

  @@index([status])
}

model Review {
  id        String   @id @default(uuid())
  name      String
  country   String
  rating    Int
  message   String
  createdAt DateTime @default(now())
}

model BlogPost {
  id         String   @id @default(uuid())
  title      String
  slug       String   @unique
  content    String
  coverImage String?
  createdAt  DateTime @default(now())
}

model FAQ {
  id       String @id @default(uuid())
  question String
  answer   String
}

model Todo {
  id        String   @id @default(uuid())
  text      String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Note {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
